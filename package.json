{
  "name": "web_temelleri",
  "version": "0.1.0",
  "description": "Türkçe interaktif modern frontend öğrenme desktop uygulaması",
  "author": "Ege Doruk Deveci",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:desktop": "set DESKTOP_BUILD=1&& next build",
    "desktop": "electron .",
    "desktop:pack": "npm run build:desktop && electron-builder --dir",
    "desktop:win": "npm run build:desktop && electron-builder --dir",
    "desktop:portable": "npm run build:desktop && electron-builder --win portable",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "dev.egedo.modernwebatolyesi",
    "productName": "Modern Web Atölyesi",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "desktop-out/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ],
      "artifactName": "Modern-Web-Atolyesi-${version}.${ext}"
    }
  }
}
